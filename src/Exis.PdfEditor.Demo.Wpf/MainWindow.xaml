<Window x:Class="Exis.PdfEditor.Demo.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Exis.PdfEditor.Demo.Wpf.Views"
        Title="Exis.PdfEditor — WPF Demo"
        MinWidth="900" MinHeight="650"
        Width="1080" Height="740"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Exis"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text=".PdfEditor"
                               FontSize="22" FontWeight="Light"
                               Foreground="{StaticResource TextBrush}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="v1.5.2  |  WPF Demo" />
            </DockPanel>
        </Border>

        <!-- StatusBar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Right" Margin="12,0,0,0">
                <ProgressBar Width="120"
                             IsIndeterminate="{Binding IsProcessing}"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Tab Control -->
        <Border Padding="16,8,16,16">
            <TabControl>
                <TabItem Header="Find &amp; Replace">
                    <views:FindReplaceView />
                </TabItem>
                <TabItem Header="Merge &amp; Split">
                    <views:MergeView />
                </TabItem>
                <TabItem Header="PDF Builder">
                    <views:BuilderView />
                </TabItem>
                <TabItem Header="Inspector">
                    <views:InspectorView />
                </TabItem>
                <TabItem Header="Redaction">
                    <views:RedactionView />
                </TabItem>
                <TabItem Header="Image Editor">
                    <views:ImageEditorView />
                </TabItem>
            </TabControl>
        </Border>
    </DockPanel>
</Window>
