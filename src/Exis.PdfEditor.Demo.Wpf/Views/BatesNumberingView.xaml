<UserControl x:Class="Exis.PdfEditor.Demo.Wpf.Views.BatesNumberingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Exis.PdfEditor.Demo.Wpf.ViewModels"
             Background="{StaticResource SurfaceBrush}"
             Padding="20,16">

    <UserControl.DataContext>
        <vm:BatesNumberingViewModel />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="720">

            <!-- Input File -->
            <GroupBox Header="Input PDF">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource StyledTextBox}"
                             Text="{Binding InputFilePath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Margin="0,0,10,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="Browse..."
                            Command="{Binding BrowseCommand}" />
                </Grid>
            </GroupBox>

            <!-- Bates Settings -->
            <GroupBox Header="Bates Stamp Settings">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource FieldLabel}" Text="Prefix" />
                        <TextBox Grid.Row="1" Grid.Column="0"
                                 Style="{StaticResource StyledTextBox}"
                                 Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Style="{StaticResource FieldLabel}" Text="Suffix" />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Style="{StaticResource StyledTextBox}"
                                 Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="0" Grid.Column="4"
                                   Style="{StaticResource FieldLabel}" Text="Start Number" />
                        <TextBox Grid.Row="1" Grid.Column="4"
                                 Style="{StaticResource StyledTextBox}"
                                 Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="0" Grid.Column="6"
                                   Style="{StaticResource FieldLabel}" Text="Digits" />
                        <TextBox Grid.Row="1" Grid.Column="6"
                                 Style="{StaticResource StyledTextBox}"
                                 Text="{Binding Digits, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource FieldLabel}" Text="Position" />
                        <ComboBox Grid.Row="1" Grid.Column="0"
                                  ItemsSource="{Binding PositionOptions}"
                                  SelectedIndex="{Binding SelectedPositionIndex}" />

                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Style="{StaticResource FieldLabel}" Text="Font Size" />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Style="{StaticResource StyledTextBox}"
                                 Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="0" Grid.Column="4"
                                   Style="{StaticResource FieldLabel}" Text="Color" />
                        <ComboBox Grid.Row="1" Grid.Column="4"
                                  ItemsSource="{Binding ColorOptions}"
                                  SelectedItem="{Binding SelectedColor}" />
                    </Grid>

                    <TextBlock Style="{StaticResource FieldLabel}"
                               Text="Confidentiality Label (optional)"
                               Margin="0,12,0,4" />
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding ConfidentialityLabel, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Content="Skip first page (cover sheet)"
                              IsChecked="{Binding SkipFirstPage}"
                              Margin="0,12,0,4" />
                    <CheckBox Content="Counter advances on skipped pages"
                              IsChecked="{Binding CounterAdvancesOnSkippedPages}" />
                </StackPanel>
            </GroupBox>

            <!-- Apply Action -->
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Apply Bates Stamp"
                    Command="{Binding ApplyCommand}"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0" />

            <!-- Processing Indicator -->
            <ProgressBar IsIndeterminate="{Binding IsProcessing}"
                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"
                         Margin="0,12,0,0" />

            <!-- Result -->
            <TextBlock Style="{StaticResource ResultText}"
                       Text="{Binding ResultMessage}"
                       Margin="0,12,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
