<UserControl x:Class="Exis.PdfEditor.Demo.Wpf.Views.FindReplaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Exis.PdfEditor.Demo.Wpf.ViewModels"
             Background="{StaticResource SurfaceBrush}"
             Padding="20,16">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="720">

            <!-- Input File -->
            <GroupBox Header="Input PDF">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource StyledTextBox}"
                             Text="{Binding InputFilePath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Margin="0,0,10,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="Browse..."
                            Command="{Binding BrowseCommand}" />
                </Grid>
            </GroupBox>

            <!-- Search Options -->
            <GroupBox Header="Search Options">
                <StackPanel>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Search text" />
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Replace with" />
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <CheckBox Content="Use regular expressions"
                                  IsChecked="{Binding UseRegex}"
                                  Margin="0,0,24,0" />
                        <CheckBox Content="Shrink text to fit"
                                  IsChecked="{Binding UseShrinkToFit}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Find &amp; Replace"
                        Command="{Binding ExecuteCommand}"
                        Margin="0,0,10,0" />
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Save As..."
                        Command="{Binding SaveAsCommand}" />
            </StackPanel>

            <!-- Processing Indicator -->
            <ProgressBar IsIndeterminate="{Binding IsProcessing}"
                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"
                         Margin="0,12,0,0" />

            <!-- Result -->
            <TextBlock Style="{StaticResource ResultText}"
                       Text="{Binding ResultMessage}"
                       Margin="0,12,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
